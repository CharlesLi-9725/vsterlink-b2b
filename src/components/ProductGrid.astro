  label:      string;
  highlight?: boolean;
}

interface ProductCard {
  model:       string;
  badge?:      string;
  name:        string;
  tagline:     string;
  description: string;
  price:       string;
  priceNote?:  string;
  features:    ProductFeature[];
  painPoint:   string;
  cta:         string;
}

interface Category {
  id:          string;
  icon:        string;
  accentColor: string;
  tag:         string;
  heading:     string;
  sub:         string;
  products:    ProductCard[];
}

