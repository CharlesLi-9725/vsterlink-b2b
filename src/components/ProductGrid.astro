---

<section id="products" class="bg-[#0A0F1E] py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-16 text-center">
      <p class="font-mono text-xs text-[#00D4AA] tracking-widest uppercase mb-3">Vsterlink Product Catalog</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
        Hardware Built for <span class="text-[#0066FF]">Fleet-Grade Operations</span>
      </h2>
      <p class="text-slate-400 text-sm mt-4 max-w-2xl mx-auto">
        Factory-direct EXW pricing · OEM/ODM branding available · LATAM LTE bands included as standard.
      </p>
    </div>

    <!-- Categories -->
    {categories.map(cat => (
      <div id={cat.id} class="mb-24 last:mb-0">

        <!-- Category header row -->
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
              style={`background: ${cat.accentColor}15; border: 1px solid ${cat.accentColor}30;`}
            >
              <!-- Fixed SVG fallback size for category icons -->
              <svg
                width="20"
                height="20"
                class="w-5 h-5 flex-shrink-0"
                fill="none"
                stroke={cat.accentColor}
                stroke-width="1.75"
                viewBox="0 0 24 24"
                set:html={iconSvgPaths[cat.icon]}
              />
            </div>
            <div>
              <p class="font-mono text-[10px] tracking-widest uppercase" style={`color: ${cat.accentColor}`}>
                {cat.tag}
              </p>
              <h3 class="text-xl sm:text-2xl font-extrabold text-white tracking-tight leading-tight mt-0.5">
                {cat.heading}
              </h3>
            </div>
          </div>
          <p class="text-slate-400 text-sm max-w-sm">{cat.sub}</p>
        </div>

        <!-- Product Cards -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {cat.products.map(product => (
            <article class="relative flex flex-col bg-[#0D1626] border border-[#1E2D4A] rounded-2xl overflow-hidden group hover:border-[#0066FF]/40 transition-all duration-300 hover:shadow-lg hover:shadow-[#0066FF]/5">

              {product.badge && (
                <div
                  class="absolute top-4 right-4 z-10 text-white text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full"
                  style={`background: ${cat.accentColor};`}
                >
                  {product.badge}
                </div>
              )}

              <div class="p-5 pb-4 border-b border-[#1E2D4A]">
                <div class="flex items-center gap-2 mb-3">
                  <span
                    class="font-mono text-xs font-bold px-2.5 py-0.5 rounded border"
                    style={`color: ${cat.accentColor}; border-color: ${cat.accentColor}40; background: ${cat.accentColor}10;`}
                  >
                    {product.model}
                  </span>
                </div>
                <h4 class="text-base font-bold text-white mb-1 leading-snug">{product.name}</h4>
                <p class="text-xs font-medium mb-3" style={`color: ${cat.accentColor}`}>{product.tagline}</p>
                <p class="text-slate-400 text-sm leading-relaxed">{product.description}</p>
              </div>

              <div class="p-5 flex-1 flex flex-col gap-4">
                <!-- Features List -->
                <ul class="space-y-2">
                  {product.features.map(feat => (
                    <li class="flex items-start gap-2">
                      <!-- Fixed SVG checkmark size template -->
                      <svg
                        width="16"
                        height="16"
                        class="w-4 h-4 mt-0.5 flex-shrink-0"
                        fill="none"
                        stroke={feat.highlight ? cat.accentColor : "#374151"}
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span class={`text-sm leading-snug ${feat.highlight ? 'text-white font-medium' : 'text-slate-400'}`}>
                        {feat.label}
                      </span>
                    </li>
                  ))}
                </ul>

                <!-- Pricing -->
                <div class="bg-[#0A0F1E] rounded-xl border border-[#1E2D4A] px-4 py-3 mt-auto">
                  <p class="text-white font-bold text-base">{product.price}</p>
                  {product.priceNote && (
                    <p class="font-mono text-[10px] text-slate-500 mt-0.5 leading-relaxed">{product.priceNote}</p>
                  )}
                </div>

                <!-- Pain point box -->
                <div class="flex items-start gap-2 bg-amber-950/20 border border-amber-500/20 rounded-lg px-3 py-2.5">
                  <!-- Fixed SVG hazard size template -->
                  <svg width="14" height="14" class="w-3.5 h-3.5 mt-0.5 flex-shrink-0 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                  <p class="text-xs text-amber-400/80 leading-relaxed">{product.painPoint}</p>
                </div>

                <!-- CTA Button -->
                <a
                  href="#contact"
                  class="flex items-center justify-center gap-2 border border-[#1E2D4A] hover:border-[#0066FF]/60 hover:bg-[#0066FF]/5 text-slate-300 hover:text-white text-sm font-semibold py-2.5 rounded-xl transition-all duration-200 group"
                >
                  {product.cta}
                  <!-- Fixed SVG chevron size template -->
                  <svg width="14" height="14" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>

            </article>
          ))}
        </div>
      </div>
    ))}

    <!-- OEM/ODM strip -->
    <div id="oem" class="mt-6 flex flex-col sm:flex-row items-center justify-between gap-4 bg-[#0D1626] border border-[#1E2D4A] rounded-2xl px-6 py-5">
      <div>
        <p class="text-white font-bold">Need custom firmware, branding, or platform integration?</p>
        <p class="text-slate-400 text-sm mt-1">
          Vsterlink OEM/ODM: logo printing, custom packaging, QXGPS/DAGPS platform setup — available from low MOQ.
        </p>
      </div>
      <a
        href="#contact"
        class="flex-shrink-0 inline-flex items-center gap-2 bg-[#0066FF] hover:bg-blue-500 text-white font-bold px-5 py-2.5 rounded-lg text-sm transition-all hover:-translate-y-px"
      >
        Discuss OEM Requirements
      </a>
    </div>

  </div>
</section>