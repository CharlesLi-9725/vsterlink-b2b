---
/**
 * TrustBanner.astro — Vsterlink
 * Real certifications (CE, FCC, RoHS, MSDS), real markets, real apps.
 * Pure CSS infinite scroll — zero JS, respects prefers-reduced-motion.
 */

 const badges = [
  { icon: "factory",  label: "Manufacturer",   value: "Shenzhen Vsterlink Intelligent Technology Co., Ltd" },
  { icon: "cert",     label: "Certifications", value: "CE · FCC · RoHS · MSDS Certified"                  },
  { icon: "signal",   label: "LTE Networks",   value: "4G Cat-1 · LTE-M · 2G Fallback — Global Coverage"  },
  { icon: "bulk",     label: "Wholesale",      value: "Low MOQ · Bulk Pricing · OEM/ODM Available"         },
  { icon: "shield",   label: "Anti-Theft",     value: "Remote Engine Cut-Off · Tamper & Vibration Alerts"  },
  { icon: "clock",    label: "Lead Time",      value: "Sample: 7 Days · Mass Production: 15–30 Days EXW"   },
  { icon: "globe",    label: "Markets",        value: "LATAM · Africa · Europe · North America"             },
  { icon: "app",      label: "Platforms",      value: "QXGPS App · DAGPS App · Viidure App"                },
];

// Duplicate for seamless infinite scroll
const doubled = [...badges, ...badges];

const iconPaths: Record<string, string> = {
  factory: "M3 21V7l7-4v4l7-4v18H3zM9 21v-6h6v6",
  cert:    "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
  signal:  "M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.142 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0",
  bulk:    "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
  shield:  "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  clock:   "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
  globe:   "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  app:     "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
};

const iconColors: Record<string, string> = {
  factory: "#00D4AA",
  cert:    "#00D4AA",
  signal:  "#0066FF",
  bulk:    "#0066FF",
  shield:  "#FF4D1C",
  clock:   "#00D4AA",
  globe:   "#0066FF",
  app:     "#00D4AA",
};
---

<div class="bg-[#0D1626] border-y border-[#1E2D4A] overflow-hidden relative">

  <!-- Fade masks -->
  <div aria-hidden="true" class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-[#0D1626] to-transparent z-10 pointer-events-none"></div>
  <div aria-hidden="true" class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-[#0D1626] to-transparent z-10 pointer-events-none"></div>

  <!-- Scrolling track -->
  <div class="flex" style="animation: trust-scroll 48s linear infinite; width: max-content;">
    {doubled.map(badge => (
      <div class="flex-shrink-0 flex items-center gap-3 px-8 py-4 border-r border-[#1E2D4A]">
        <div class="w-8 h-8 rounded-lg bg-[#1E2D4A] flex items-center justify-center flex-shrink-0">
          <!-- Protection: Added native fallback dimensions width="16" height="16" inside sliding cells -->
          <svg
            width="16"
            height="16"
            class="w-4 h-4 flex-shrink-0"
            fill="none"
            stroke={iconColors[badge.icon] ?? "#00D4AA"}
            stroke-width="1.75"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[badge.icon]}/>
          </svg>
        </div>
        <div class="flex flex-col leading-none gap-0.5">
          <span class="font-mono text-[9px] text-slate-600 tracking-widest uppercase">{badge.label}</span>
          <span class="text-sm font-semibold text-slate-200 whitespace-nowrap">{badge.value}</span>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  @keyframes trust-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    [style*="trust-scroll"] { animation: none; }
  }
</style>